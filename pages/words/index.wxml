<view class="page">

  <!-- ===== 介绍/选模式页 ===== -->
  <block wx:if="{{view === 'intro'}}">
    <view class="topbar"><text class="title">单词学习</text></view>
    <view class="day-badge">第 {{dayNumber}} 天 · 艾宾浩斯计划</view>

    <view class="mode-cards">
      <view class="mode-card" bindtap="startCard">
        <text class="mode-icon">📇</text>
        <text class="mode-name">普通翻卡</text>
        <text class="mode-desc">看中文翻牌认识英文</text>
      </view>
      <view class="mode-card" bindtap="startDictation">
        <text class="mode-icon">✍️</text>
        <text class="mode-name">听写模式</text>
        <text class="mode-desc">先输入拼写再翻卡</text>
      </view>
      <view class="mode-card" bindtap="startSpelling">
        <text class="mode-icon">🎯</text>
        <text class="mode-name">拼写模式</text>
        <text class="mode-desc">拼对=认识，拼错=不认识</text>
      </view>
    </view>

    <view class="stat-row">
      <view class="stat-box"><text class="s-label">最高分</text><text class="s-val">{{highScore}}</text></view>
      <view class="stat-box"><text class="s-label">今天第几天</text><text class="s-val">{{dayNumber}}</text></view>
    </view>

    <view class="tool-list">
      <view class="tool-item" bindtap="onSelectDay">📅 选择学习天数</view>
      <view class="tool-item" bindtap="onShowStats">📊 学习统计</view>
      <view class="tool-item" bindtap="onShowLearned">📚 已学习单词</view>
      <view class="tool-item" bindtap="onShowFavorites">⭐ 收藏单词</view>
      <view class="tool-item" bindtap="onFavoriteDrill">⭐ 练收藏词</view>
      <view class="tool-item" bindtap="onWrongDrill">🔁 错词重练</view>
      <view class="tool-item" bindtap="onShowTomorrow">🔭 明日计划</view>
      <view class="tool-item" bindtap="onShowMastered">✅ 已掌握管理</view>
      <view class="tool-item" bindtap="onShowWordPool">🗑️ 词库管理（删除已会词）</view>
      <view class="tool-item" bindtap="onShowCustomWords">📝 自定义单词表</view>
    </view>
  </block>

  <!-- ===== 游戏页 ===== -->
  <block wx:if="{{view === 'game'}}">
    <!-- 顶部统计栏 -->
    <view class="game-header">
      <view class="hstat"><text class="hl">分数</text><text class="hv">{{score}}</text></view>
      <view class="hstat"><text class="hl">最高</text><text class="hv">{{highScore}}</text></view>
      <view class="hstat"><text class="hl">连击</text><text class="hv">{{streak}}</text></view>
      <view class="hstat"><text class="hl">剩余</text><text class="hv">{{remain}}</text></view>
    </view>

    <!-- 进度信息 -->
    <view class="mode-bar">
      <text class="mode-text">{{phase2Info ? phase2Info : modeInfo}}</text>
      <text class="progress-text">{{currentIdx}}/{{total}}</text>
    </view>

    <!-- 单词卡 -->
    <view class="word-card {{revealed ? 'revealed' : ''}}">
      <text class="prompt-text">{{prompt}}</text>
      <text class="answer-text" wx:if="{{revealed}}">{{answer}}</text>
      <text class="answer-placeholder" wx:else>（点翻卡查看）</text>
        <view class="memory-tip-box" wx:if="{{revealed && exampleSentence}}">
          <text class="memory-tip-label">📝 例句（{{examplePos}}）</text>
          <text class="memory-tip-text">{{exampleSentence}}</text>
          <text class="memory-tip-text">{{exampleSentenceZh}}</text>
        </view>
    </view>

    <!-- 拼写/听写输入框 -->
    <view class="spell-box" wx:if="{{showInput}}">
      <input
        class="spell-input" value="{{inputVal}}" bindinput="onInput"
        placeholder="输入英文拼写" confirm-type="done" bindconfirm="onCheckInput"
        autocomplete="off" autocorrect="off" autocapitalize="none"
        disabled="{{waitingConfirm}}" />
      <button class="btn-check" bindtap="onCheckInput" disabled="{{waitingConfirm}}">提交</button>
      <text class="spell-result {{waitingConfirm ? 'spell-result-wrong' : ''}}" wx:if="{{inputResult}}">{{inputResult}}</text>
      <!-- 拼写错误确认按钮：点击后才跳下一题 -->
      <view class="btn-confirm-wrong" wx:if="{{waitingConfirm}}" bindtap="onConfirmWrong">
        <text class="confirm-wrong-icon">👆</text>
        <text class="confirm-wrong-text">我记住了，下一个</text>
      </view>
    </view>

    <!-- 翻卡按钮 -->
    <button class="btn-flip" bindtap="onFlip" disabled="{{flipDisabled}}">{{flipText || '翻卡'}}</button>

    <!-- 认识/不认识 -->
    <view class="judge-row">
      <button class="btn-know" bindtap="onKnow" disabled="{{knowDisabled}}">✅ 认识</button>
      <button class="btn-dont" bindtap="onDont" disabled="{{dontDisabled}}">❌ 不认识</button>
    </view>

    <!-- 辅助工具行 -->
    <view class="aux-row">
      <view class="aux-btn {{isFav ? 'on' : ''}}" bindtap="onToggleFav">{{isFav ? '★ 已收藏' : '☆ 收藏'}}</view>
      <view class="aux-btn" bindtap="onDeleteWord">🗑️ 删除</view>
      <view class="aux-btn" bindtap="onSpeakWord">🔊 发音</view>
    </view>

    <!-- 折叠工具 -->
    <view class="tools-toggle" bindtap="toggleTools">⚙️ 工具 {{toolsExpanded ? '▲' : '▼'}}</view>
    <view class="tools-panel" wx:if="{{toolsExpanded}}">
      <view class="tool-item" bindtap="onShowStats">📊 学习统计</view>
      <view class="tool-item" bindtap="onShowLearned">📚 已学习单词</view>
      <view class="tool-item" bindtap="onShowFavorites">⭐ 收藏单词</view>
      <view class="tool-item" bindtap="onFavoriteDrill">⭐ 练收藏词</view>
      <view class="tool-item" bindtap="onWrongDrill">🔁 错词重练</view>
      <view class="tool-item" bindtap="onShowTomorrow">🔭 明日计划</view>
      <view class="tool-item" bindtap="onShowMastered">✅ 已掌握管理</view>
      <view class="tool-item" bindtap="onSelectDay">📅 切换天数</view>
      <view class="tool-item {{autoSpeak ? 'on' : ''}}" bindtap="onToggleAutoSpeak">🔊 自动发音：{{autoSpeak ? '开' : '关'}}</view>
    </view>
  </block>

  <!-- ===== 结算页 ===== -->
  <block wx:if="{{view === 'result'}}">
    <view class="result-page">
      <text class="result-title">{{rIsNew ? '🎉 新纪录！' : '✅ 完成今日任务'}}</text>
      <view class="result-grid">
        <view class="rg-item"><text class="rl">本局得分</text><text class="rv accent">{{rScore}}</text></view>
        <view class="rg-item"><text class="rl">历史最高</text><text class="rv">{{rHigh}}</text></view>
        <view class="rg-item"><text class="rl">认识</text><text class="rv green">{{rKnow}}</text></view>
        <view class="rg-item"><text class="rl">不认识</text><text class="rv red">{{rDont}}</text></view>
        <view class="rg-item"><text class="rl">最高连击</text><text class="rv">{{rStreak}}</text></view>
        <view class="rg-item"><text class="rl">总练习次数</text><text class="rv">{{rRuns}}</text></view>
      </view>
      <button class="btn-primary" bindtap="onRestart">再来一轮</button>
      <button class="btn-secondary" bindtap="onReplayWrong" wx:if="{{wrongCount > 0}}">练错词（{{wrongCount}}个）</button>
      <button class="btn-secondary" bindtap="onBackToIntro">返回首页</button>
    </view>
  </block>

  <!-- ===== 已掌握管理页 ===== -->
  <block wx:if="{{view === 'mastered'}}">
    <view class="list-page">
      <view class="list-header">
        <text class="list-title">已掌握词（{{masteredList.length}}）</text>
        <text class="back-btn" bindtap="onBackToIntro">← 返回</text>
      </view>
      <view wx:if="{{!masteredList.length}}" class="empty-tip">暂无已掌握词</view>
      <view class="word-list-item" wx:for="{{masteredList}}" wx:key="en">
        <view class="wli-left">
          <text class="wli-zh">{{item.zh}}</text>
          <text class="wli-en">{{item.en}}</text>
        </view>
        <button class="wli-btn" data-en="{{item.en}}" bindtap="onUnmaster">取消</button>
      </view>
    </view>
  </block>

  <!-- ===== 收藏单词页 ===== -->
  <block wx:if="{{view === 'favorites'}}">
    <view class="list-page">
      <view class="list-header">
        <text class="list-title">收藏单词（{{favoriteList.length}}）</text>
        <text class="back-btn" bindtap="onBackToIntro">← 返回</text>
      </view>
      <button class="btn-primary" wx:if="{{favoriteList.length}}" bindtap="onFavoriteDrill">开始练收藏词</button>
      <view wx:if="{{!favoriteList.length}}" class="empty-tip">暂无收藏单词</view>
      <view class="word-list-item" wx:for="{{favoriteList}}" wx:key="en">
        <view class="wli-left">
          <text class="wli-zh">{{item.zh}}</text>
          <text class="wli-en">{{item.en}}</text>
        </view>
        <button class="wli-btn" data-en="{{item.en}}" bindtap="onUnfavorite">取消</button>
      </view>
    </view>
  </block>

  <!-- ===== 已学习单词页 ===== -->
  <block wx:if="{{view === 'learned'}}">
    <view class="list-page">
      <view class="list-header">
        <text class="list-title">已学习单词（{{learnedList.length}}）</text>
        <text class="back-btn" bindtap="onBackToIntro">← 返回</text>
      </view>
      <view wx:if="{{!learnedList.length}}" class="empty-tip">暂时还没有已学习单词</view>
      <view class="word-list-item" wx:for="{{learnedList}}" wx:key="en">
        <view class="wli-left">
          <text class="wli-zh">{{item.zh}}</text>
          <text class="wli-en">{{item.en}}</text>
        </view>
      </view>
    </view>
  </block>

  <!-- ===== 学习统计页 ===== -->
  <block wx:if="{{view === 'stats'}}">
    <view class="list-page">
      <view class="list-header">
        <text class="list-title">学习统计</text>
        <text class="back-btn" bindtap="onBackToIntro">← 返回</text>
      </view>
      <view class="result-grid stats-grid">
        <view class="rg-item"><text class="rl">总练习次数</text><text class="rv accent">{{statsRuns}}</text></view>
        <view class="rg-item"><text class="rl">最高分</text><text class="rv">{{statsHigh}}</text></view>
        <view class="rg-item"><text class="rl">已学习单词</text><text class="rv">{{statsLearned}}</text></view>
        <view class="rg-item"><text class="rl">已掌握词</text><text class="rv green">{{statsMastered}}</text></view>
        <view class="rg-item"><text class="rl">收藏词数</text><text class="rv">{{statsFav}}</text></view>
        <view class="rg-item"><text class="rl">当前天数</text><text class="rv">{{dayNumber}}</text></view>
      </view>
    </view>
  </block>

  <!-- ===== 明日计划页 ===== -->
  <block wx:if="{{view === 'tomorrow'}}">
    <view class="list-page">
      <view class="list-header">
        <text class="list-title">明日计划</text>
        <text class="back-btn" bindtap="onBackToIntro">← 返回</text>
      </view>
      <view class="plan-section">
        <text class="plan-label">🆕 明日新词（{{tomorrowNewCount}}）</text>
        <view class="word-list-item" wx:for="{{tomorrowNew}}" wx:key="en">
          <text class="wli-zh">{{item.zh}}</text>
          <text class="wli-en">{{item.en}}</text>
        </view>
      </view>
      <view class="plan-section">
        <text class="plan-label">🔁 明日复习（{{tomorrowReviewCount}}）</text>
        <view class="word-list-item" wx:for="{{tomorrowReview}}" wx:key="en">
          <text class="wli-zh">{{item.zh}}</text>
          <text class="wli-en">{{item.en}}</text>
        </view>
      </view>
    </view>
  </block>

  <!-- ===== 词库管理（删除已会词）===== -->
  <block wx:if="{{view === 'wordpool'}}">
    <view class="list-page">
      <view class="list-header">
        <text class="list-title">词库管理（{{wordPoolTotal - wordPoolDeleted}}/{{wordPoolTotal}}）</text>
        <text class="back-btn" bindtap="onBackToIntro">← 返回</text>
      </view>
      <view class="search-box">
        <input class="search-input" value="{{wordPoolSearch}}" bindinput="onWordPoolSearch" placeholder="搜索单词（英文或中文）..." />
      </view>
      <view class="wordpool-toggle">
        <text class="wpt-tab {{wordPoolFilter === 'all' ? 'active' : ''}}" bindtap="onWordPoolFilter" data-filter="all">全部</text>
        <text class="wpt-tab {{wordPoolFilter === 'active' ? 'active' : ''}}" bindtap="onWordPoolFilter" data-filter="active">学习中</text>
        <text class="wpt-tab {{wordPoolFilter === 'deleted' ? 'active' : ''}}" bindtap="onWordPoolFilter" data-filter="deleted">已删除</text>
      </view>
      <view wx:if="{{!wordPoolList.length}}" class="empty-tip">没有匹配的单词</view>
      <view class="word-list-item" wx:for="{{wordPoolList}}" wx:key="en">
        <view class="wli-left">
          <text class="wli-zh">{{item.zh}}</text>
          <text class="wli-en">{{item.en}}</text>
        </view>
        <button class="wli-btn {{item._deleted ? 'wli-btn-restore' : ''}}" data-en="{{item.en}}" bindtap="onToggleWordDelete">
          {{item._deleted ? '恢复' : '删除'}}
        </button>
      </view>
    </view>
  </block>

  <!-- ===== 自定义单词表 ===== -->
  <block wx:if="{{view === 'customWords'}}">
    <view class="list-page">
      <view class="list-header">
        <text class="list-title">自定义单词表（{{customWordsList.length}}）</text>
        <text class="back-btn" bindtap="onBackToIntro">← 返回</text>
      </view>
      <!-- 添加单个单词 -->
      <view class="custom-add-box">
        <text class="custom-add-title">添加单词</text>
        <view class="custom-add-row">
          <input class="custom-input-en" value="{{customEn}}" bindinput="onCustomEnInput" placeholder="英文" />
          <input class="custom-input-zh" value="{{customZh}}" bindinput="onCustomZhInput" placeholder="中文释义" />
          <button class="custom-btn-add" bindtap="onAddCustomWord" disabled="{{!customEn || !customZh}}">添加</button>
        </view>
      </view>
      <!-- 批量导入 -->
      <view class="custom-add-box">
        <text class="custom-add-title">批量导入（每行格式：英文 中文）</text>
        <textarea class="custom-textarea" value="{{customBatch}}" bindinput="onCustomBatchInput" placeholder="apple 苹果&#10;hello 你好&#10;goodbye 再见" maxlength="5000" auto-height="{{true}}" />
        <button class="btn-primary" bindtap="onImportCustomWords" disabled="{{!customBatch}}">批量导入</button>
      </view>
      <!-- 自定义单词列表 -->
      <view wx:if="{{!customWordsList.length}}" class="empty-tip">暂无自定义单词</view>
      <view class="word-list-item" wx:for="{{customWordsList}}" wx:key="en">
        <view class="wli-left">
          <text class="wli-zh">{{item.zh}}</text>
          <text class="wli-en">{{item.en}}</text>
          <text class="wli-custom-tag">自定义</text>
        </view>
        <button class="wli-btn" data-en="{{item.en}}" bindtap="onRemoveCustomWord">删除</button>
      </view>
    </view>
  </block>

</view>
