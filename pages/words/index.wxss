.page { min-height: 100vh; background: #f5f6f8; padding: 0 24rpx 80rpx; box-sizing: border-box; }

/* === 通用 === */
.topbar { padding: 32rpx 0 16rpx; text-align: center; }
.title { font-size: 52rpx; font-weight: 800; color: #7a3fd4; }
.day-badge { text-align: center; font-size: 28rpx; color: #888; margin-bottom: 24rpx; }

/* === 模式选择卡 === */
.mode-cards { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.mode-card { flex: 1; background: #fff; border-radius: 20rpx; padding: 28rpx 12rpx; text-align: center; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.06); display: flex; flex-direction: column; gap: 8rpx; }
.mode-icon { font-size: 48rpx; }
.mode-name { font-size: 30rpx; font-weight: 700; color: #1e2430; }
.mode-desc { font-size: 24rpx; color: #888; }

/* === 统计栏 === */
.stat-row { display: flex; gap: 16rpx; margin-bottom: 20rpx; }
.stat-box { flex: 1; background: #f2f4f7; border-radius: 18rpx; padding: 22rpx 0; text-align: center; }
.s-label { display: block; font-size: 26rpx; color: #888; }
.s-val { display: block; font-size: 44rpx; font-weight: 700; color: #111; margin-top: 4rpx; }

/* === 工具列表 === */
.tool-list { background: #fff; border-radius: 20rpx; overflow: hidden; }
.tool-item { padding: 28rpx 32rpx; font-size: 30rpx; color: #2a3040; border-bottom: 1rpx solid #f0f0f0; }
.tool-item:last-child { border-bottom: none; }
.tool-item.on { color: #7a3fd4; font-weight: 600; }

/* === 游戏头部 === */
.game-header { display: flex; justify-content: space-between; padding: 20rpx 0 12rpx; }
.hstat { flex: 1; text-align: center; }
.hl { display: block; font-size: 24rpx; color: #888; }
.hv { display: block; font-size: 40rpx; font-weight: 700; color: #111; }

.mode-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.mode-text { font-size: 26rpx; color: #7a3fd4; }
.progress-text { font-size: 26rpx; color: #888; }

/* === 单词卡 === */
.word-card { min-height: 340rpx; background: #fff; border-radius: 24rpx; border: 2rpx solid #e8ebf0; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40rpx; margin-bottom: 20rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); transition: border-color 0.2s; }
.word-card.revealed { border-color: #a5d6a7; }
.prompt-text { font-size: 60rpx; font-weight: 700; color: #0f1522; text-align: center; }
.answer-text { font-size: 52rpx; font-weight: 600; color: #2360a8; text-align: center; margin-top: 24rpx; }
.answer-placeholder { font-size: 32rpx; color: #ccc; margin-top: 24rpx; }

/* === 记忆技巧 === */
.memory-tip-box { width: 100%; margin-top: 28rpx; background: linear-gradient(135deg, #f0f7ff, #e8f5e9); border-radius: 16rpx; padding: 20rpx 24rpx; border-left: 6rpx solid #7a3fd4; box-sizing: border-box; }
.memory-tip-label { display: block; font-size: 24rpx; font-weight: 700; color: #7a3fd4; margin-bottom: 8rpx; letter-spacing: 1rpx; }
.memory-tip-text { display: block; font-size: 28rpx; color: #2a3040; line-height: 1.7; }

/* === 拼写输入 === */
.spell-box { background: #fff; border-radius: 18rpx; padding: 20rpx 24rpx; margin-bottom: 16rpx; border: 1rpx solid #e0e4ea; }
.spell-input { width: 100%; height: 72rpx; font-size: 32rpx; border-bottom: 2rpx solid #e0e4ea; padding: 0 8rpx; }
.btn-check { margin-top: 16rpx; height: 72rpx; display: flex; align-items: center; justify-content: center; background: #f0f4ff; color: #4f7df0; border-radius: 14rpx; font-size: 30rpx; font-weight: 600; border: none; width: 100%; padding: 0; }
.btn-check[disabled] { opacity: 0.35; }
.spell-result { display: block; margin-top: 12rpx; font-size: 28rpx; color: #555; text-align: center; }
.spell-result-wrong { color: #ef5350; font-size: 30rpx; font-weight: 600; }

/* 拼写错误确认按钮 */
.btn-confirm-wrong { margin-top: 20rpx; height: 80rpx; display: flex; align-items: center; justify-content: center; gap: 12rpx; background: linear-gradient(135deg, #ff7043, #ef5350); color: #fff; border-radius: 18rpx; font-size: 30rpx; font-weight: 700; border: none; animation: pulse 0.8s ease-in-out infinite alternate; }
.confirm-wrong-icon { font-size: 36rpx; }
.confirm-wrong-text { font-size: 30rpx; font-weight: 700; }
@keyframes pulse { from { opacity: 0.85; transform: scale(0.98); } to { opacity: 1; transform: scale(1.01); } }

/* === 按钮 === */
.btn-flip { width: 100%; height: 90rpx; display: flex; align-items: center; justify-content: center; background: #4f7df0; color: #fff; border-radius: 22rpx; font-size: 34rpx; font-weight: 700; border: none; margin-bottom: 18rpx; padding: 0; }
.btn-flip[disabled] { background: #b0bec5; }

.judge-row { display: flex; gap: 20rpx; margin-bottom: 18rpx; }
.btn-know { flex: 1; height: 90rpx; display: flex; align-items: center; justify-content: center; background: #4caf50; color: #fff; border-radius: 22rpx; font-size: 32rpx; font-weight: 700; border: none; padding: 0; }
.btn-dont { flex: 1; height: 90rpx; display: flex; align-items: center; justify-content: center; background: #ef5350; color: #fff; border-radius: 22rpx; font-size: 32rpx; font-weight: 700; border: none; padding: 0; }
.btn-know[disabled], .btn-dont[disabled] { opacity: 0.35; }

/* === 辅助工具行 === */
.aux-row { display: flex; gap: 12rpx; margin-bottom: 16rpx; flex-wrap: wrap; }
.aux-btn { flex: 1; min-width: 180rpx; height: 60rpx; display: flex; align-items: center; justify-content: center; background: #f5f6f8; border-radius: 30rpx; font-size: 26rpx; color: #555; text-align: center; border: 1rpx solid #e0e4ea; }
.aux-btn.on { background: #fff3cd; color: #b8860b; border-color: #ffe082; }

/* === 折叠工具 === */
.tools-toggle { text-align: center; padding: 14rpx; font-size: 28rpx; color: #7a3fd4; }
.tools-panel { background: #fff; border-radius: 20rpx; overflow: hidden; margin-top: 8rpx; }

/* === 结算页 === */
.result-page { padding: 40rpx 0; }
.result-title { display: block; font-size: 48rpx; font-weight: 800; color: #7a3fd4; text-align: center; margin-bottom: 32rpx; }
.result-grid { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 32rpx; }
.rg-item { width: calc(50% - 8rpx); background: #fff; border-radius: 18rpx; padding: 24rpx; text-align: center; box-sizing: border-box; }
.rl { display: block; font-size: 26rpx; color: #888; margin-bottom: 6rpx; }
.rv { display: block; font-size: 44rpx; font-weight: 700; color: #111; }
.rv.accent { color: #7a3fd4; }
.rv.green { color: #4caf50; }
.rv.red { color: #ef5350; }

.btn-primary { width: 100%; height: 88rpx; display: flex; align-items: center; justify-content: center; background: #7a3fd4; color: #fff; border-radius: 22rpx; font-size: 34rpx; font-weight: 700; border: none; margin-bottom: 16rpx; padding: 0; }
.btn-secondary { width: 100%; height: 80rpx; display: flex; align-items: center; justify-content: center; background: #fff; color: #555; border-radius: 22rpx; font-size: 30rpx; border: 1rpx solid #dde2e8; margin-bottom: 14rpx; padding: 0; }

/* === 列表页 === */
.list-page { padding: 0; }
.list-header { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 0 16rpx; }
.list-title { font-size: 36rpx; font-weight: 700; color: #1e2430; }
.back-btn { font-size: 28rpx; color: #7a3fd4; }
.empty-tip { text-align: center; color: #aaa; padding: 60rpx; font-size: 30rpx; }
.word-list-item { display: flex; align-items: center; background: #fff; border-radius: 16rpx; padding: 20rpx 24rpx; margin-bottom: 12rpx; }
.wli-left { flex: 1; }
.wli-zh { display: block; font-size: 30rpx; color: #444; }
.wli-en { display: block; font-size: 32rpx; font-weight: 600; color: #2360a8; margin-top: 4rpx; }
.wli-btn { min-width: 100rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; background: #fde8e8; color: #c62828; border-radius: 14rpx; font-size: 26rpx; border: none; }

/* === 明日计划 === */
.plan-section { margin-bottom: 28rpx; }
.plan-label { display: block; font-size: 30rpx; font-weight: 600; color: #7a3fd4; margin-bottom: 12rpx; padding: 8rpx 0; }

.stats-grid { margin-top: 8rpx; }

/* === 词库管理 === */
.search-box { padding: 8rpx 0 16rpx; }
.search-input { width: 100%; height: 72rpx; background: #f2f4f7; border-radius: 16rpx; padding: 0 24rpx; font-size: 28rpx; color: #333; box-sizing: border-box; }

.wordpool-toggle { display: flex; gap: 12rpx; margin-bottom: 16rpx; }
.wpt-tab { flex: 1; text-align: center; padding: 14rpx 0; background: #f2f4f7; border-radius: 14rpx; font-size: 26rpx; color: #666; }
.wpt-tab.active { background: #7a3fd4; color: #fff; font-weight: 600; }
.wli-btn.wli-btn-restore { background: #e8f5e9; color: #2e7d32; }

/* === 自定义单词表 === */
.custom-add-box { background: #fff; border-radius: 16rpx; padding: 20rpx 24rpx; margin-bottom: 16rpx; }
.custom-add-title { display: block; font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 14rpx; }

.custom-add-row { display: flex; gap: 12rpx; align-items: center; }
.custom-input-en { flex: 1; height: 68rpx; background: #f2f4f7; border-radius: 12rpx; padding: 0 16rpx; font-size: 28rpx; }
.custom-input-zh { flex: 1; height: 68rpx; background: #f2f4f7; border-radius: 12rpx; padding: 0 16rpx; font-size: 28rpx; }
.custom-btn-add { min-width: 110rpx; height: 68rpx; display: flex; align-items: center; justify-content: center; background: #7a3fd4; color: #fff; border-radius: 12rpx; font-size: 28rpx; font-weight: 600; border: none; padding: 0; }
.custom-btn-add[disabled] { background: #ccc; }

.custom-textarea { width: 100%; min-height: 140rpx; background: #f2f4f7; border-radius: 12rpx; padding: 16rpx; font-size: 26rpx; line-height: 1.8; color: #333; box-sizing: border-box; margin-top: 12rpx; margin-bottom: 16rpx; }

.wli-custom-tag { display: inline-block; margin-left: 8rpx; padding: 2rpx 10rpx; background: #e8f5e9; color: #388e3c; border-radius: 8rpx; font-size: 22rpx; font-weight: 600; vertical-align: middle; }
