.page { min-height: 100vh; background: #f5f6f8; padding: 0 28rpx 100rpx; box-sizing: border-box; }

/* === 顶部 === */
.topbar { padding: 48rpx 0 20rpx; text-align: center; }
.title { display: block; font-size: 64rpx; font-weight: 900; color: #7a3fd4; letter-spacing: 4rpx; }
.subtitle { display: block; font-size: 28rpx; color: #aaa; margin-top: 8rpx; }

/* === Logo === */
.logo-card { display: flex; justify-content: center; margin: 20rpx 0 32rpx; }
.logo { width: 160rpx; height: 160rpx; border-radius: 32rpx; box-shadow: 0 8rpx 32rpx rgba(122,63,212,0.15); }

/* === 入口卡片 === */
.entry-cards { display: flex; flex-direction: column; gap: 20rpx; margin-bottom: 36rpx; }
.entry-card { display: flex; align-items: center; background: #fff; border-radius: 24rpx; padding: 36rpx 28rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.07); gap: 24rpx; }
.words-card { border-left: 8rpx solid #4f7df0; }
.grammar-card { border-left: 8rpx solid #7a3fd4; }
.entry-icon { font-size: 60rpx; }
.entry-info { flex: 1; }
.entry-name { display: block; font-size: 38rpx; font-weight: 700; color: #1e2430; }
.entry-desc { display: block; font-size: 26rpx; color: #888; margin-top: 6rpx; }
.entry-arrow { font-size: 48rpx; color: #ccc; }

/* === 特色介绍 === */
.features { background: #fff; border-radius: 24rpx; padding: 8rpx 0; }
.feature-item { display: flex; align-items: center; gap: 20rpx; padding: 24rpx 28rpx; border-bottom: 1rpx solid #f3f4f6; }
.feature-item:last-child { border-bottom: none; }
.fi-icon { font-size: 48rpx; }
.fi-info { flex: 1; }
.fi-title { display: block; font-size: 30rpx; font-weight: 600; color: #1e2430; }
.fi-desc { display: block; font-size: 26rpx; color: #888; margin-top: 4rpx; }
