<view class="page">
  <view class="topbar">
    <text class="title">Ash英语</text>
    <text class="subtitle">英语学习助手</text>
  </view>

  <!-- Logo 区域 -->
  <view class="logo-card">
    <image class="logo" src="/words/logo.jpg" mode="aspectFit"></image>
  </view>

  <!-- 入口卡片 -->
  <view class="entry-cards">
    <view class="entry-card words-card" bindtap="goWords">
      <view class="entry-icon">📚</view>
      <view class="entry-info">
        <text class="entry-name">单词学习</text>
        <text class="entry-desc">第 {{wordDayNumber}} 天 · 最高分 {{wordHighScore}}</text>
      </view>
      <text class="entry-arrow">›</text>
    </view>
  </view>

  <!-- 特色介绍 -->
  <view class="features">
    <view class="feature-item">
      <text class="fi-icon">🧠</text>
      <view class="fi-info">
        <text class="fi-title">艾宾浩斯复习</text>
        <text class="fi-desc">1/2/4/7/15天间隔，科学记忆</text>
      </view>
    </view>
    <view class="feature-item">
      <text class="fi-icon">🎯</text>
      <view class="fi-info">
        <text class="fi-title">多遍强化拼写</text>
        <text class="fi-desc">错词必须拼写通过，直到零错误</text>
      </view>
    </view>
  </view>
</view>
